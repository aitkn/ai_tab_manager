{
  "manifest_version": 3,
  "name": "Smart Tab Manager",
  "version": "2.0",
  "description": "Categorize and manage tabs using AI",
  "permissions": [
    "tabs",
    "storage",
    "management"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}